{
  "name": "rv-design",
  "version": "0.1.0",
  "description": "RV Design — a token-driven Vue 3 component library. Natural/architectural palette, light + dark (OS-following) theming, all driven by CSS custom properties.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "design-system",
    "component-library",
    "design-tokens",
    "css-variables",
    "dark-mode"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "files": [
    "dist",
    "src",
    "styles.css",
    "tokens",
    "css",
    "readme.md"
  ],
  "main": "./dist/rv-design.umd.cjs",
  "module": "./dist/rv-design.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/rv-design.js",
      "require": "./dist/rv-design.umd.cjs"
    },
    "./styles.css": "./dist/rv-design.css",
    "./css": "./styles.css",
    "./tokens/*": "./tokens/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "storybook dev --port 6006",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . && stylelint \"**/*.{css,scss,vue}\" --ignore-path .gitignore",
    "lint:fix": "eslint . --fix && stylelint \"**/*.{css,scss,vue}\" --fix --ignore-path .gitignore",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build --output-dir storybook-static"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/vue3-vite": "^8.6.18",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^9.5.0",
    "eslint-plugin-vue": "^9.26.0",
    "postcss-html": "^1.7.0",
    "sass": "^1.77.0",
    "storybook": "^8.6.18",
    "stylelint": "^16.6.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
