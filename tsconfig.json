{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "rv-design": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", ".storybook/**/*", "stories/**/*"],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
